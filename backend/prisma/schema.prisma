// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum for project types
enum ProjectType {
  POOL
  EXTENSION
  SHED
  FENCE
  NEW_CONSTRUCTION
  OTHER
}

// Enum for project status
enum ProjectStatus {
  DRAFT
  QUESTIONNAIRE
  ANALYZING
  COMPLETED
}

// Enum for authorization types
enum AuthorizationType {
  NONE
  DP  // Déclaration Préalable
  PC  // Permis de Construire
  PA  // Permis d'Aménager
}

// Enum for chat message roles
enum ChatRole {
  USER
  ASSISTANT
}

// Enum for purchasable packs
enum Pack {
  ETUDE   // 39€ - analyse complète, documents, Q&A 30 jours
  DOSSIER // 149€ - + CERFA prérempli + plans (pas encore disponible)
  PREMIUM // 349€ - + relecture humaine + accompagnement (pas encore disponible)
}

// Enum for purchase status
enum PurchaseStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// User model
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  firstName    String?
  lastName     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  projects     Project[]
  purchases    Purchase[]
  consents     Consent[]

  @@map("users")
}

// Consent model - append-only proof log of legal consents: CGU acceptance at
// registration, CGV acceptance + express withdrawal-right waiver before
// checkout (art. L221-28 Code de la consommation).
model Consent {
  id        String      @id @default(uuid())
  userId    String
  type      ConsentType
  version   String      // Version of the accepted document (e.g. "1.0 (2026-07-17)")
  context   String?     // Extra reference, e.g. the purchase id for CGV consents
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("consents")
}

enum ConsentType {
  CGU
  CGV_RETRACTATION
}

// Project model
model Project {
  id                    String                 @id @default(uuid())
  userId                String
  name                  String
  projectType           ProjectType
  status                ProjectStatus          @default(DRAFT)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  address               Address?
  questionnaireResponse QuestionnaireResponse?
  analysisResult        AnalysisResult?
  chatMessages          ChatMessage[]
  purchases             Purchase[]

  @@index([userId])
  @@map("projects")
}

// Address model - stores geocoded address information
model Address {
  id                String   @id @default(uuid())
  projectId         String   @unique
  rawInput          String   // Original address input by user
  lat               Float    // Latitude
  lon               Float    // Longitude
  inseeCode         String?  // INSEE code of the commune
  parcelId          String?  // Cadastral parcel identifier
  pluZone           String?  // PLU zone code (e.g., U, AU, N, A)
  pluZoneLabel      String?  // PLU zone label/description
  cityName          String?  // City name
  postCode          String?  // Postal code
  // Flood zone information from Géorisques
  floodZone         String?  // Type of flood zone (null, rouge, bleu, etc.)
  floodZoneLevel    String?  // Risk level (fort, moyen, faible)
  floodZoneSource   String?  // Source document (PPRI name)
  // ABF (Monument Historique) protection
  isAbfProtected    Boolean  @default(false)
  abfType           String?  // Type of protection (MH, SPR, AVAP, etc.)
  abfPerimeter      String?  // Description of protection perimeter
  abfMonumentName   String?  // Name of the related monument
  // Other natural risks
  seismicZone       String?  // Seismic zone (1-5)
  clayRisk          String?  // Clay shrink-swell risk
  // Noise exposure (PEB - Plan d'Exposition au Bruit)
  isInNoiseZone     Boolean  @default(false)
  noiseZone         String?  // PEB zone (1=A, 2=B, 3=C, 4=D)
  noiseAirportName  String?  // Airport name
  noiseAirportCode  String?  // OACI code (e.g., LFRS)
  noiseRestrictions String?  @db.Text // Description of restrictions
  // Full regulatory snapshot, persisted when the address is attached to the
  // project so display, PDF export and LLM analysis reuse it instead of
  // re-calling the external APIs (IGN, Géorisques, GPU...)
  fullLocationInfo      Json?     // FullLocationInfo as returned by /urbanisme/full-info
  parcelInfo            Json?     // ParcelInfo (cadastre) as returned by /geocoding/parcel
  locationInfoFetchedAt DateTime? // When the snapshot was fetched from the external APIs
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

// QuestionnaireResponse model - stores questionnaire answers
model QuestionnaireResponse {
  id          String   @id @default(uuid())
  projectId   String   @unique
  responses   Json     // JSON object storing all question responses
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("questionnaire_responses")
}

// AnalysisResult model - stores LLM analysis results
model AnalysisResult {
  id                String            @id @default(uuid())
  projectId         String            @unique
  authorizationType AuthorizationType
  constraints       Json              // JSON array of constraints identified
  requiredDocuments Json              // JSON array of required documents
  llmResponse       String?           @db.Text // Raw LLM response for debugging
  feasibilityStatus String?           // compatible, compatible_a_risque, probablement_incompatible
  summary           String?           @db.Text // Summary of the analysis
  metrics           Json?             // Per-stage latency, token usage, cache hits for this analysis run
  createdAt         DateTime          @default(now())
  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("analysis_results")
}

// ChatMessage model - conversation between the user and the assistant about
// an analyzed project (questions/réponses post-analyse)
model ChatMessage {
  id        String   @id @default(uuid())
  projectId String
  role      ChatRole
  content   String   @db.Text
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("chat_messages")
}

// Purchase model - one row per Stripe Checkout attempt for a project pack.
// The paywall (analyse complète, documents, chat) is unlocked when the
// project has at least one PAID purchase.
model Purchase {
  id                    String         @id @default(uuid())
  userId                String
  projectId             String
  pack                  Pack
  status                PurchaseStatus @default(PENDING)
  amountCents           Int            // Price in cents at purchase time
  currency              String         @default("eur")
  stripeSessionId       String?        @unique // Stripe Checkout session id
  stripePaymentIntentId String?
  receiptUrl            String?        // Stripe charge receipt, backfilled lazily
  paidAt                DateTime?
  chatAccessUntil       DateTime?      // End of the Q&A window (paidAt + 30 jours)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project               Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([userId])
  @@map("purchases")
}

// Cache of LLM-extracted PLU rules, one entry per (zone, commune).
// The extraction is project-type-agnostic so a single entry serves every
// project and project type in the zone.
model PluRulesCache {
  id              String   @id @default(uuid())
  zoneCode        String   // PLU zone code
  inseeCode       String   // INSEE code of the commune
  rules           Json     // Structured rules extracted from the règlement
  sourceUrl       String?  // URL of the règlement PDF
  documentId      String?  // Geoportail Urbanisme document id
  documentName    String?
  documentType    String?  // PLU, PLUi, CC...
  documentDate    String?  // Approbation/publication date from GPU
  extractionModel String?  // OpenAI model used for the extraction
  schemaVersion   Int      @default(1) // Bumped when the extraction output schema changes
  extractedAt     DateTime @default(now())
  expiresAt       DateTime // When the cache should be refreshed

  @@unique([zoneCode, inseeCode])
  @@index([documentId, zoneCode])
  @@map("plu_rules_cache")
}

// Maps a Geoportail Urbanisme document to an already-uploaded OpenAI file,
// so extracting several zones of the same (often large) PLUi PDF skips the
// re-download and re-upload.
model PluDocumentFile {
  id           String   @id @default(uuid())
  documentId   String   @unique // Geoportail Urbanisme document id
  openaiFileId String
  sourceUrl    String?
  fetchedAt    DateTime @default(now())

  @@map("plu_document_files")
}
