# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://urbanisme:urbanisme_password@localhost:5434/urbanisme

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
# Optional: separate (cheaper/faster) model for the PLU rules extraction
# OPENAI_EXTRACTION_MODEL=gpt-4o-mini

# Stripe Configuration (paiement des packs)
# Clé secrète (mode test : sk_test_..., prod : sk_live_...) depuis https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Secret de signature du webhook (whsec_...) : créez un endpoint sur
# https://dashboard.stripe.com/webhooks pointant vers <backend>/api/billing/webhook
# avec les événements checkout.session.completed, checkout.session.async_payment_succeeded,
# checkout.session.async_payment_failed, checkout.session.expired, charge.refunded.
# En local : stripe listen --forward-to localhost:3001/api/billing/webhook
# (le whsec_... affiché par stripe listen est stable pour votre machine/compte)
STRIPE_WEBHOOK_SECRET=

# Server Configuration
NODE_ENV=development
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
